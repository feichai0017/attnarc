---
import { navigation, repositoryUrl } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const {
  title = "Loom Kernels — Rust-first GPU operators for LLM inference",
  description = "Backend-independent Rust contracts, handwritten CUDA kernels, and engine-qualified evidence for LLM inference.",
  active = "",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const local = (href: string) => `${base}${href}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(`${base}/og.png`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08110d" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Loom Kernels" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={local("/")} aria-label="Loom Kernels home">
          <span class="brand-mark" aria-hidden="true">LK</span>
          <span class="brand-copy">
            <strong>Loom Kernels</strong>
            <small>Rust × CUDA</small>
          </span>
        </a>

        <nav aria-label="Primary navigation">
          {navigation.map((item) => (
            <a
              href={local(item.href)}
              aria-current={active === item.label ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <a class="github-link" href={repositoryUrl} target="_blank" rel="noreferrer">
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </header>

      <main id="content">
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          <span class="footer-mark" aria-hidden="true">//</span>
          <strong>Loom Kernels</strong>
          <p>Own the inference operator boundary.</p>
        </div>
        <div class="footer-links">
          <a href={local("/docs/")}>Get started</a>
          <a href={local("/benchmarks/")}>Evidence</a>
          <a href={`${repositoryUrl}/blob/main/LICENSE`}>MIT License</a>
        </div>
        <p class="footer-note">Rust contracts. CUDA execution. Measured claims.</p>
      </footer>
    </div>
  </body>
</html>
