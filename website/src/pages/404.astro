---
import SiteLayout from "../layouts/SiteLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<SiteLayout title="Not found — Loom Kernels">
  <section class="page-hero">
    <p class="eyebrow">Status / 404</p>
    <h1>This boundary is unsupported.</h1>
    <p>The requested page is outside the current contract.</p>
    <div class="hero-actions">
      <a class="button primary" href={`${base}/`}>Return home&nbsp; →</a>
    </div>
  </section>
</SiteLayout>
